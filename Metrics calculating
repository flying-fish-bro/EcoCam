import math
MISSING = -1000
def is_valid(value):
    return value != MISSING and value is not None
def safe_div(a, b):
    if not is_valid(a) or not is_valid(b) or b == 0:
        return MISSING
    return a / b
def process_datacenter_metrics(
    ENERGY_TOTAL,
    ENERGY_IT,
    WATER,
    COOLING_ENERGY,
    SERVER_COUNT,
    ACTIVE_SERVERS,
    UTILIZATION,
    ELECTRICITY_COST,
    WATER_COST,
    EMMISIONS
):
    result = {}
    result["ENERGY_TOTAL"] = ENERGY_TOTAL
    result["ENERGY_IT"] = ENERGY_IT
    result["WATER"] = WATER
    result["COOLING_ENERGY"] = COOLING_ENERGY
    result["SERVER_COUNT"] = SERVER_COUNT
    result["ACTIVE_SERVERS"] = ACTIVE_SERVERS
    result["UTILIZATION"] = UTILIZATION
    result["ELECTRICITY_COST"] = ELECTRICITY_COST
    result["WATER_COST"] = WATER_COST
    result["EMMISIONS"] = EMMISIONS
    if is_valid(ENERGY_TOTAL) and is_valid(ENERGY_IT):
        result["ENERGY_WASTE"] = ENERGY_TOTAL - ENERGY_IT
    else:
        result["ENERGY_WASTE"] = MISSING
    result["COOLING_RATIO"] = safe_div(COOLING_ENERGY, ENERGY_TOTAL)
    result["ACTIVE_SERVER_RATIO"] = safe_div(ACTIVE_SERVERS, SERVER_COUNT)
    result["ENERGY_PER_SERVER"] = safe_div(ENERGY_TOTAL, SERVER_COUNT)
    result["ENERGY_PER_ACTIVE_SERVER"] = safe_div(ENERGY_TOTAL, ACTIVE_SERVERS)
    result["WATER_PER_ENERGY"] = safe_div(WATER, ENERGY_TOTAL)
    result["EMISSIONS_PER_ENERGY"] = safe_div(EMMISIONS, ENERGY_TOTAL)
    total_cost = 0
    has_any_cost = False
    if is_valid(ELECTRICITY_COST):
        total_cost += ELECTRICITY_COST
        has_any_cost = True
    if is_valid(WATER_COST):
        total_cost += WATER_COST
        has_any_cost = True
    result["TOTAL_COST"] = total_cost if has_any_cost else MISSING
    result["PUE_ESTIMATE"] = safe_div(ENERGY_TOTAL, ENERGY_IT)
    score = 0
    used = 0
    if is_valid(result["ENERGY_WASTE"]):
        score += result["ENERGY_WASTE"] * 0.35
        used += 1
    if is_valid(WATER):
        score += WATER * 0.20
        used += 1
    if is_valid(EMMISIONS):
        score += EMMISIONS * 0.30
        used += 1
    if is_valid(result["TOTAL_COST"]):
        score += result["TOTAL_COST"] * 0.15
        used += 1
    result["SUSTAINABILITY_SCORE"] = score if used > 0 else MISSING
    return result
